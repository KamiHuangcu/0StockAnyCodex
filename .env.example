# .env format example for this project
# Note:
# 1. Keep this file as UTF-8 text.
# 2. One KEY=VALUE per line.
# 3. Do not add quotes unless the value itself needs quotes.
# 4. Current stock_scanner.py does not auto-load .env yet.
#    This file is for documenting and standardizing FinMind-related settings.

# Required for future FinMind API integration / token-based requests
FINMIND_API_TOKEN=your_finmind_api_token

# Optional reference fields
FINMIND_USER_ID=your_finmind_user_id
FINMIND_EMAIL=your_email@example.com
FINMIND_IS_VERIFIED=true
FINMIND_API_LIMIT_PER_HOUR=600
FINMIND_API_USED_COUNT=0
